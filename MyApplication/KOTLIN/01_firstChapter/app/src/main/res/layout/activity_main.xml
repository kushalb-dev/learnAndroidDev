<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Spinner
        android:id="@+id/spinner1_mainActivity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="120dp"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.3"
        app:layout_constraintStart_toStartOf="parent"
        android:textAlignment="center"
        android:gravity="center"
        android:entries="@array/spinner1_mainActivity_items"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/button1_mainActivity"
        />

    <Button
        android:id="@+id/button1_mainActivity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/button1_mainActivity_placeholder"
        android:textAllCaps="false"
        android:layout_marginTop="@dimen/button1_mainActivity_marginTop"
        android:layout_marginBottom="@dimen/button1_mainActivity_marginBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/spinner1_mainActivity"
        app:layout_constraintBottom_toTopOf="@id/textView1_mainActivity"
        />

    <TextView
        android:id="@+id/textView1_mainActivity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/textView1_mainActivity_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button1_mainActivity"
        app:layout_constraintBottom_toBottomOf="parent"
        />



</androidx.constraintlayout.widget.ConstraintLayout>